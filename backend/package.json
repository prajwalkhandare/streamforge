{
  "name": "streamforge-backend",
  "version": "1.0.0",
  "description": "Backend API for StreamForge OTT Platform",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "db:migrate": "node src/db/migrate.js",
    "db:seed": "node src/db/seed.js",
    "docker:build": "docker build -t streamforge-backend .",
    "docker:run": "docker run -p 5000:5000 streamforge-backend"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "compression": "^1.7.4",
    "dotenv": "^16.3.1",
    "pg": "^8.11.3",
    "pg-pool": "^3.6.1",
    "redis": "^4.6.10",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "aws-sdk": "^2.1503.0",
    "@aws-sdk/client-s3": "^3.484.0",
    "@aws-sdk/client-cloudfront": "^3.484.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.484.0",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.1",
    "winston": "^3.11.0",
    "winston-cloudwatch": "^6.1.1",
    "uuid": "^9.0.1",
    "axios": "^1.6.2",
    "socket.io": "^4.5.4",
    "joi": "^17.11.0",
    "node-cache": "^5.1.2",
    "bull": "^4.11.5",
    "ioredis": "^5.3.2",
    "node-fetch": "^2.7.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.55.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "prettier": "^3.1.0",
    "@types/jest": "^29.5.10",
    "mongodb-memory-server": "^9.1.3",
    "dotenv-test": "^1.0.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": ["ott", "streaming", "video", "netflix-clone", "aws", "eks"],
  "author": "Prajwal Khandare",
  "license": "MIT"
}
