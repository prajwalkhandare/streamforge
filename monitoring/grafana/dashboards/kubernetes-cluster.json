{
  "dashboard": {
    "title": "Kubernetes Cluster Monitoring",
    "description": "StreamForge Kubernetes Cluster Metrics",
    "tags": ["kubernetes", "streamforge", "cluster"],
    "timezone": "browser",
    "editable": true,
    "refresh": "30s",
    "panels": [
      {
        "title": "CPU Usage",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "sum(rate(container_cpu_usage_seconds_total{container!=\"\", namespace=\"streamforge\"}[5m])) by (pod)",
            "legendFormat": "{{ pod }}"
          }
        ],
        "yaxes": [
          {"format": "percent", "label": "CPU Usage"},
          {"format": "short"}
        ],
        "title": "Pod CPU Usage"
      },
      {
        "title": "Memory Usage",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "sum(container_memory_working_set_bytes{container!=\"\", namespace=\"streamforge\"}) by (pod)",
            "legendFormat": "{{ pod }}"
          }
        ],
        "yaxes": [
          {"format": "bytes", "label": "Memory Usage"},
          {"format": "short"}
        ],
        "title": "Pod Memory Usage"
      },
      {
        "title": "Network I/O",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "sum(rate(container_network_receive_bytes_total{namespace=\"streamforge\"}[5m])) by (pod)",
            "legendFormat": "Receive - {{ pod }}"
          },
          {
            "expr": "sum(rate(container_network_transmit_bytes_total{namespace=\"streamforge\"}[5m])) by (pod)",
            "legendFormat": "Transmit - {{ pod }}"
          }
        ],
        "yaxes": [
          {"format": "bytes", "label": "Network I/O"},
          {"format": "short"}
        ],
        "title": "Network I/O per Pod"
      },
      {
        "title": "Node Status",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "count(kube_node_status_condition{condition=\"Ready\", status=\"true\"})",
            "legendFormat": "Ready Nodes"
          }
        ],
        "title": "Ready Nodes"
      },
      {
        "title": "Pod Status",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 8},
        "targets": [
          {
            "expr": "count(kube_pod_status_phase{phase=\"Running\", namespace=\"streamforge\"})",
            "legendFormat": "Running Pods"
          }
        ],
        "title": "Running Pods"
      }
    ]
  }
}
